// DaySync Database Schema
// Rule: Every model maps to a table in your SCHEMA-V1.md doc

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// Fixed sets of values. Postgres enforces these.
// ============================================

enum Role {
  ADMIN // Created the community
  MEMBER // Joined via invite link
}

enum MeetingStatus {
  UPCOMING // Confirmed, hasn't happened yet
  CANCELLED // Cancelled by either member
  DONE // End time has passed
}

// ============================================
// CORE TABLES
// ============================================

// The group everything else belongs to.
// Created once manually in V1 via createCommunity()

model Community {
  id         String   @id @default(uuid())
  name       String
  inviteLink String   @unique // Resettable by admin. Old link stops working.
  adminId    String // Points to the Member who created this community
  createdAt  DateTime @default(now())

  // Relations — tells Prisma how tables connect
  memberships Membership[]
  schedules   Schedule[]
  meetings    Meeting[]
}

// A person who belongs to one or more Communities.
// userId points to Better Auth's user table — that's where email lives.

model Member {
  id          String   @id @default(uuid())
  userId      String   @unique // Foreign key to Better Auth user table
  displayName String
  timezone    String // IANA format e.g. "America/Los_Angeles"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  memberships   Membership[]
  schedules     Schedule[]
  meetingMember MeetingMember[]
}

// Weekly availability for a Member in a specific Community.
// One row per time block. A member can have many rows.
// Example: Monday 6:30pm-9:00pm = day:1 startHour:18 startMinute:30 endHour:21 endMinute:0

model Schedule {
  id          String   @id @default(uuid())
  memberId    String
  communityId String
  day         Int // 0-6. Sunday=0, Saturday=6
  startHour   Int // 0-23 in 24hr format
  startMinute Int // 0 or 30 only
  endHour     Int // 0-23 in 24hr format
  endMinute   Int // 0 or 30 only
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  member    Member    @relation(fields: [memberId], references: [id])
  community Community @relation(fields: [communityId], references: [id])
}

// A confirmed plan between two Members to cowork or talk.
// meetLink is generated by Google Meet API after createMeeting() runs.

model Meeting {
  id          String        @id @default(uuid())
  communityId String
  startTime   DateTime // Stored in UTC always
  endTime     DateTime // Stored in UTC always
  meetLink    String // Generated by Google Meet API
  status      MeetingStatus @default(UPCOMING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  community     Community       @relation(fields: [communityId], references: [id])
  meetingMember MeetingMember[]
}

// ============================================
// JUNCTION TABLES
// Handle many-to-many relationships
// ============================================

// Connects Members to Communities.
// One row per Member per Community.
// A Member cannot belong to the same Community twice.

model Membership {
  id          String   @id @default(uuid())
  memberId    String
  communityId String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  // Relations
  member    Member    @relation(fields: [memberId], references: [id])
  community Community @relation(fields: [communityId], references: [id])

  // Constraint — one membership per member per community
  @@unique([memberId, communityId])
}

// Connects Members to Meetings.
// One row per Member per Meeting.

model MeetingMember {
  id        String @id @default(uuid())
  meetingId String
  memberId  String

  // Relations
  meeting Meeting @relation(fields: [meetingId], references: [id])
  member  Member  @relation(fields: [memberId], references: [id])
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
